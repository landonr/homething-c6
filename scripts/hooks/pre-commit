#!/usr/bin/env bash
#
# Pre-commit hook: keep fabrication outputs and README renders in lockstep
# with the design.
#
# When the schematic or PCB is part of the commit, regenerate all fab outputs
# (gerbers + drill + pick-and-place + BOM) via scripts/regen-fab.sh and stage
# export/ so the checked-in outputs never drift from the source.
#
# README assets regenerate per source file via scripts/render-readme-assets.sh:
# a staged PCB rerenders the board views (3D PNGs + flat SVGs), a staged
# schematic rerenders schematic.svg; docs/readme-assets/ is then staged.
#
# Install (once per clone):
#   git config core.hooksPath scripts/hooks
#
# Skip for a one-off commit:
#   git commit --no-verify
#
# Note: gerber/drill headers embed a creation timestamp, so any commit that
# touches the board will restage all of export/ even if geometry is unchanged.
#
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Policy guard: never let a co-author / AI-attribution trailer enter the repo.
# Scans staged *additions* across all files (AGENTS.md included). Matches real
# trailer-shaped lines and known AI-bot emails, so prose documenting the rule
# (e.g. "no Co-Authored-By trailers") does not trip it.
ADDED="$(git diff --cached --unified=0 --no-color -- . ':(exclude)*.gbr' ':(exclude)*.drl' ':(exclude)scripts/hooks/*' | grep -E '^\+' | grep -vE '^\+\+\+' || true)"
if grep -iqE '^\+[[:space:]]*co[- ]?authored[- ]?by:[[:space:]]*.+<[^>]*@' <<<"$ADDED" \
	|| grep -iqE 'noreply@anthropic\.com|[0-9]+\+copilot@users\.noreply\.github\.com' <<<"$ADDED"; then
	echo "[pre-commit] BLOCKED: a staged change adds a co-author / AI-attribution trailer" >&2
	echo "[pre-commit] Repo forbids Co-Authored-By / Claude / Copilot attribution. Remove it, or use --no-verify." >&2
	exit 1
fi

STAGED="$(git diff --cached --name-only)"
SCH_STAGED=false
PCB_STAGED=false
grep -qE '^c6remote-kicad/c6remote\.kicad_sch$' <<<"$STAGED" && SCH_STAGED=true
grep -qE '^c6remote-kicad/c6remote\.kicad_pcb$' <<<"$STAGED" && PCB_STAGED=true

# Only regenerate when a design file is actually part of this commit.
if ! $SCH_STAGED && ! $PCB_STAGED; then
	exit 0
fi

echo "[pre-commit] schematic/PCB staged -> regenerating fabrication outputs"
"$REPO_ROOT/scripts/regen-fab.sh"
git add "$REPO_ROOT/c6remote-kicad/export/"
echo "[pre-commit] export/ regenerated and staged"

if $PCB_STAGED && $SCH_STAGED; then
	echo "[pre-commit] PCB + schematic staged -> rerendering all README assets"
	"$REPO_ROOT/scripts/render-readme-assets.sh" --only all
elif $PCB_STAGED; then
	echo "[pre-commit] PCB staged -> rerendering README board views"
	"$REPO_ROOT/scripts/render-readme-assets.sh" --only board
else
	echo "[pre-commit] schematic staged -> rerendering README schematic SVG"
	"$REPO_ROOT/scripts/render-readme-assets.sh" --only schematic
fi
git add "$REPO_ROOT/docs/readme-assets/"
echo "[pre-commit] docs/readme-assets/ regenerated and staged"
